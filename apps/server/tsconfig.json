{
  "compilerOptions": {
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "isolatedModules": true,
    "esModuleInterop": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "outDir": "./dist",
    "lib": [
      "ESNext"
    ],
    "types": [
      "node"
    ],
    "baseUrl": "./",
  },
  "include": [
    "src/**/*",
    "tests/**/*"
  ]
}